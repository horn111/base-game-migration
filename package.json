{
  "name": "base-game-migration",
  "version": "0.0.0",
  "private": true,
  "description": "Move existing games to Base with payment verification, in-game balances, entitlements, and Builder Code attribution.",
  "license": "MIT",
  "author": "horn111 <https://github.com/horn111>",
  "repository": {
    "type": "git",
    "url": "https://github.com/horn111/base-game-migration.git"
  },
  "bugs": {
    "url": "https://github.com/horn111/base-game-migration/issues"
  },
  "homepage": "https://github.com/horn111/base-game-migration#readme",
  "keywords": [
    "base",
    "base-pay",
    "base-game-migration",
    "game-migration",
    "game-backend",
    "liveops",
    "entitlements",
    "credits",
    "tickets",
    "builder-codes",
    "attribution",
    "onchain",
    "web3"
  ],
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 build",
    "clean": "pnpm -r --workspace-concurrency=1 clean",
    "dev": "pnpm --filter @base-game-migration/demo dev",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "pnpm -r --workspace-concurrency=1 test",
    "test:watch": "vitest",
    "typecheck": "pnpm -r --workspace-concurrency=1 typecheck",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.17.0",
    "next": "^16.1.6",
    "prettier": "^3.4.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "8.60.1",
    "vitest": "^2.1.8"
  }
}
